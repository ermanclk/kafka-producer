{
  "type": "record",
  "name": "UserEvent",
  "namespace": "com.example.avro",
  "fields": [
    { "name": "userId",    "type": "string" },
    { "name": "eventType", "type": {
        "type": "enum",
        "name": "EventType",
        "symbols": ["LOGIN", "LOGOUT", "PAGE_VIEW", "PURCHASE", "ADD_TO_CART"]
    }},
    { "name": "timestamp", "type": "string" },
    { "name": "metadata",  "type": { "type": "map", "values": "string" }, "default": {} }
  ]
}
